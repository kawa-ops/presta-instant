generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("freelancer") // admin | freelancer
  active        Boolean   @default(true)
  // Freelancer fields
  phone         String?
  siret         String?
  specialty     String?
  address       String?
  profilePicUrl String?
  // Relations
  productions   Production[] @relation("AssignedTo")
  invoices      Invoice[]
  notifications Notification[]
  payouts       MonthlyPayout[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Production {
  id             String    @id @default(cuid())
  title          String
  client         String
  brief          String?
  sourcesLink    String?
  deliveryLink   String?
  priority       String    @default("normal") // urgent | high | normal | low
  status         String    @default("a_faire") // a_faire | en_cours | en_attente | livre | valide
  price          Float?
  deadline       DateTime?
  productionDate DateTime?
  internalNotes  String?
  archived       Boolean   @default(false)
  assignedToId   String?
  assignedTo     User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  invoices       Invoice[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Invoice {
  id           String    @id @default(cuid())
  freelancerId String
  freelancer   User      @relation(fields: [freelancerId], references: [id])
  productionId String?
  production   Production? @relation(fields: [productionId], references: [id])
  fileUrl      String?
  amount       Float?
  status       String    @default("pending") // pending | paid
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
}

model MonthlyPayout {
  id              String    @id @default(cuid())
  freelancerId    String
  freelancer      User      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  month           String    // "2026-07"
  validatedAmount Float     @default(0)
  projectCount    Int       @default(0)
  invoiceUrl      String?
  invoiceStatus   String    @default("pending") // pending | uploaded | paid
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([freelancerId, month])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // task_completed | invoice_uploaded | invoice_paid | deadline_reminder | new_task
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorName String
  action    String
  target    String?
  createdAt DateTime @default(now())
}
