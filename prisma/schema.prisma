generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("freelancer") // admin | freelancer
  active        Boolean   @default(true)
  // Freelancer fields
  phone         String?
  siret         String?
  specialty     String?
  address       String?
  profilePicUrl String?
  rates         String?   // JSON: negotiated rates per service type
  calendarToken String?   @unique // secret for the personal ICS feed
  unavailableDates String? // JSON: list of ISO dates the provider is off
  // Relations
  productions   Production[] @relation("AssignedTo")
  invoices      Invoice[]
  notifications Notification[]
  payouts       MonthlyPayout[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Production {
  id             String    @id @default(cuid())
  title          String
  client         String
  brief          String?
  sourcesLink    String?
  referenceLink  String?   // musiques, inspirations, moodboards…
  deliveryLink   String?
  priority       String    @default("normal") // urgent | high | normal | low
  status         String    @default("a_faire") // a_faire | en_cours | en_attente | livre | valide
  price          Float?    // paid to the freelancer
  clientPrice    Float?    // billed to the client (margin = clientPrice - price)
  deadline       DateTime?
  productionDate DateTime?
  internalNotes  String?
  lastFeedback   String?   // Latest revision comments from Lucas
  shareToken     String?   @unique // public client-tracking link
  clientApprovedAt DateTime? // client clicked "approve" on the portal
  finalLink      String?   // final downloadable delivery sent to the client
  payoutMonth    String?   // "2026-07" — which monthly payout this production was credited to ("none" = removed from billing)
  archived       Boolean   @default(false)
  assignedToId   String?
  assignedTo     User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  invoices       Invoice[]
  deliveryVersions DeliveryVersion[]
  comments       Comment[]
  events         ProductionEvent[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([assignedToId, status])
  @@index([deadline])
  @@index([payoutMonth])
}

model ProductionEvent {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  status       String     // the status the production entered
  createdAt    DateTime   @default(now())

  @@index([productionId])
}

model DeliveryVersion {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  url          String
  version      Int
  createdAt    DateTime   @default(now())

  @@index([productionId])
}

model Comment {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  authorName   String
  authorRole   String     // admin | freelancer
  body         String
  createdAt    DateTime   @default(now())

  @@index([productionId])
}

model Invoice {
  id           String    @id @default(cuid())
  freelancerId String
  freelancer   User      @relation(fields: [freelancerId], references: [id])
  productionId String?
  production   Production? @relation(fields: [productionId], references: [id])
  fileUrl      String?
  amount       Float?
  status       String    @default("pending") // pending | paid
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
}

model MonthlyPayout {
  id              String    @id @default(cuid())
  freelancerId    String
  freelancer      User      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  month           String    // "2026-07"
  validatedAmount Float     @default(0)
  projectCount    Int       @default(0)
  invoiceUrl      String?
  invoiceStatus   String    @default("pending") // pending | uploaded | paid
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([freelancerId, month])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // task_completed | invoice_uploaded | invoice_paid | deadline_reminder | new_task
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model CustomAchievement {
  id          String   @id @default(cuid())
  emoji       String
  label       String
  description String?
  xp          Int      @default(25)
  createdAt   DateTime @default(now())
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  key       String
  createdAt DateTime @default(now())

  @@unique([userId, key])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorName String
  action    String
  target    String?
  createdAt DateTime @default(now())
}
